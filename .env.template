# ============================================================================
# SiliconExpert Demo Site — environment template
# Copy this file to `.env` and fill in the real values. `.env` is gitignored.
# ============================================================================

# ---------- SiliconExpert ProductAPI (REQUIRED) ----------
# Sign in to https://www.siliconexpert.com to obtain API credentials.
SILICONEXPERT_LOGIN=<your-siliconexpert-login>
SILICONEXPERT_API_KEY=<your-siliconexpert-api-key>
SILICONEXPERT_API_BASE=https://api.siliconexpert.com/ProductAPI/search

# ---------- Excel mapping file (REQUIRED) ----------
# Advantech PN → MPN → Manufacturer → SE_ComID lookup table.
# File is not committed to the repo; place it at ./acl_pn_comID/ or point
# EXCEL_PATH at its actual location.
EXCEL_PATH=./acl_pn_comID/V_SE_MPN_LIST20260128.xlsx
# Options: 'startup' loads on boot (default), 'on_demand' loads lazily.
EXCEL_LOAD_STRATEGY=startup

# ---------- Backend mode (local dev) ----------
# Both Flask and Next.js expose the same /api/* contract; pick one to run.
#   flask  -> python backend/flask_app.py   (port 8000)
#   nextjs -> npm run dev                   (port 3001)
BACKEND_MODE=flask
BACKEND_PORT=8000

# ---------- Recent-searches store ----------
# SQLite file for Flask · JSON file (same prefix, .json) for Next.js.
# Both are gitignored. Will be auto-created on first write.
RECENT_DB_PATH=./recent_searches.db

# ============================================================================
# Advantech Denodo data platform (OPTIONAL)
# ----------------------------------------------------------------------------
# Used only as a fallback when a searched PN is not in the Excel mapping.
# The app still works without Denodo — SiliconExpert queries are independent.
# Leave values blank or remove if you don't have Denodo access.
# ============================================================================

DENODO_SERVER=<denodo-host>
DENODO_DATABASE=<denodo-database>
DENODO_PORT=9996
DENODO_USERNAME=<denodo-username>
DENODO_PASSWORD=<denodo-password>

# Connection mode: odbc | rest | cache_only
# 'rest' is the recommended path for this app.
DENODO_MODE=rest

# ----- REST API (production) -----
DENODO_REST_BASE_URL=<https://...:9443/server/<db>>
DENODO_REST_USERNAME=<denodo-rest-username>
DENODO_REST_PASSWORD=<denodo-rest-password>
DENODO_REST_VERIFY_SSL=false

# ----- REST API (development) — toggled by DENODO_REST_USE_DEV_API -----
DENODO_REST_USE_DEV_API=false
DENODO_REST_DEV_BASE_URL=<https://dev-host:9443/server/<db>>
DENODO_REST_DEV_USERNAME=<dev-username>
DENODO_REST_DEV_PASSWORD=<dev-password>

# ---------- Misc ----------
DEV_MODE=false
CACHE_ENABLED=true
CACHE_DATABASE_PATH=./denodo_cache.db
AUDIT_ENABLED=true
AUDIT_USER_IDENTITY=<your-username>
ERROR_LOG_PATH=./logs/errors.log
